# This .env file defines environment variables that are necessary for the development environment
# to function properly. So, it MUST NOT be ignored in version control, and it MUST NOT include any
# sensitive information such as secrets or credentials.

VOLUMES_DIR=/var/volumes
GIT_CREDENTIALS_DIR=${VOLUMES_DIR}/git-credentials
XDG_DIR=${VOLUMES_DIR}/xdg
GOPATH_DIR=${VOLUMES_DIR}/go
BEAR_LOG_DIR=${VOLUMES_DIR}/bear-logs