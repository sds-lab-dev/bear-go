{
    "name": "Bear AI developer in Go for local development",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "options": [
            "--pull"
        ],
        "args": {
            "GITHUB_ACTIONS": "${localEnv:GITHUB_ACTIONS}",
            "WORKSPACE_ROOT": "${containerWorkspaceFolder}"
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "debug.allowBreakpointsEverywhere": true,
                "editor.codeActionsOnSave": {
                    "source.organizeImports": "always"
                }
            },
            "extensions": [
                "github.copilot-chat",
                "golang.go"
            ]
        }
    },
    "remoteUser": "root",
    "mounts": [
        "source=bear-go-persist-volume,target=/root/.persist,type=volume"
    ],
    "containerEnv": {},
    "initializeCommand": "${localWorkspaceFolder}/.devcontainer/scripts/initialize_script.sh \"${containerWorkspaceFolder}\"",
    "postCreateCommand": "${containerWorkspaceFolder}/.devcontainer/scripts/post_create_script.sh \"${containerWorkspaceFolder}\"",
    "postStartCommand": "${containerWorkspaceFolder}/.devcontainer/scripts/post_start_script.sh \"${containerWorkspaceFolder}\""
}