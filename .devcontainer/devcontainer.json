{
    "name": "Bear AI developer in Go for local development",
    "dockerComposeFile": "docker-compose.yaml",
    "service": "dev",
    "containerUser": "root",
    "remoteUser": "root",
    "workspaceFolder": "/workspace",
    "containerEnv": {
        "DEVCONTAINER_WORKSPACE": "/workspace"
    },
    "overrideCommand": false,
    "shutdownAction": "stopCompose",
    "customizations": {
        "vscode": {
            "settings": {
                "debug.allowBreakpointsEverywhere": true,
                "editor.codeActionsOnSave": {
                    "source.organizeImports": "always"
                },
                "python.defaultInterpreterPath": "${workspaceFolder}/langgraph/.venv"
            },
            "extensions": [
                "golang.go",
                "github.copilot-chat",
                "anthropic.claude-code",
                "google.gemini-cli-vscode-ide-companion",
                "openai.chatgpt"
            ]
        }
    },
    "initializeCommand": "${localWorkspaceFolder}/.devcontainer/scripts/initialize_script.sh \"${localWorkspaceFolder}\"",
    "postCreateCommand": "${containerWorkspaceFolder}/.devcontainer/scripts/post_create_script.sh \"${containerWorkspaceFolder}\"",
    "postStartCommand": "${containerWorkspaceFolder}/.devcontainer/scripts/post_start_script.sh \"${containerWorkspaceFolder}\""
}